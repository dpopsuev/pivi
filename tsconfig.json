{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "types": ["node"],
    "verbatimModuleSyntax": true,
    "allowImportingTsExtensions": true
  },
  "include": ["extension.ts", "test/**/*.ts", "vitest.config.ts"]
}
